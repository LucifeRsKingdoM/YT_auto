# =============================================================
#  YOUTUBE AUTOMATION TOOL  —  configuration
#  Copy this file to ".env" and fill in your own values.
#  Never commit the real .env file anywhere public.
# =============================================================

# ---- App -----------------------------------------------------
# Generate with:  python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_string

# Encryption key for stored API tokens/credentials.
# Generate with:  python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
FERNET_KEY=change_me_generate_a_fernet_key

# ---- Which database to use ----------------------------------
# cloud = Supabase (Postgres) + Supabase Storage for video files
# local = local MySQL + local disk folder for video files
DB_MODE=local

# ---- CLOUD mode: Supabase -----------------------------------
# From Supabase dashboard > Project Settings > Database (connection string, "URI")
SUPABASE_DB_URL=postgresql+psycopg2://postgres:YOUR_DB_PASSWORD@db.YOURPROJECT.supabase.co:5432/postgres
# From Supabase dashboard > Project Settings > API
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_BUCKET=videos

# ---- LOCAL mode: MySQL --------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=yt_automation
# Where video files are stored on disk in local mode
LOCAL_STORAGE_DIR=storage/videos

# ---- Admin accounts (seeded on first run) -------------------
# Two accounts only. Each has a login password AND a separate safe word.
# The safe word is required to confirm any credential change.
ADMIN1_USERNAME=Cipher
ADMIN1_PASSWORD=put_your_login_password_here
ADMIN1_SAFEWORD=put_a_separate_safe_word_here

ADMIN2_USERNAME=Lucifer
ADMIN2_PASSWORD=put_your_login_password_here
ADMIN2_SAFEWORD=put_a_separate_safe_word_here

# ---- YouTube (OAuth desktop/web client from Google Cloud) ---
# Create at: Google Cloud Console > APIs & Services > Credentials
# Enable "YouTube Data API v3" and "YouTube Analytics API".
YT_CLIENT_ID=your_google_oauth_client_id
YT_CLIENT_SECRET=your_google_oauth_client_secret
# Must match a redirect URI registered on the OAuth client.
YT_REDIRECT_URI=http://localhost:5000/integrations/youtube/callback
# Default privacy for uploaded videos: private | unlisted | public
# NOTE: Google forces API uploads to "private" until your project passes
# its free one-time audit. Keep "private" until you are verified.
YT_DEFAULT_PRIVACY=private

# ---- Telegram -----------------------------------------------
# Create a bot via @BotFather to get the token.
# Get your chat id by messaging the bot then visiting
# https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
